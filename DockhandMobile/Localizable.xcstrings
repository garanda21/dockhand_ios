    "This removes every image not used by any container in the selected Dockhand environment.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina todas las imágenes que no esté usando ningún contenedor en el entorno de Dockhand seleccionado."
          }
        }
      }
    },
    "This removes the full image object from the selected Dockhand environment.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina el objeto completo de la imagen del entorno de Dockhand seleccionado."
          }
        }
      }
    },
    "This removes the saved URL, token and per-server environment selection.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina la URL guardada, el token y la selección de entorno por servidor."
          }
        }
      }
    },
    "This removes the stack from the selected Dockhand environment. Deleting volumes also removes attached persistent data.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina el stack del entorno de Dockhand seleccionado. Eliminar los volúmenes también elimina los datos persistentes adjuntos."
          }
        }
      }
    },
    "This removes untagged intermediate layers in the selected Dockhand environment.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto elimina las capas intermedias sin etiqueta del entorno de Dockhand seleccionado."
          }
        }
      }
    },
    "This stops and removes the containers created by this stack in the selected environment.": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto detiene y elimina los contenedores creados por este stack en el entorno seleccionado."
          }
        }
      }
    },
